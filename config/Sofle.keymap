#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/ext_power.h>

#define BASE 0
#define GAMING 1
#define SYMBOLS 2
#define EDITING 3
#define ADJUST 4

/ {

   // Activate ADJUST layer by pressing raise and lower
    conditional_layers {
        compatible = "zmk,conditional-layers";
        adjust_layer {
            if-layers = <SYMBOLS EDITING>;
            then-layer = <ADJUST>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
// ------------------------------------------------------------------------------------------------------------------
// | ESC  | 1 | 2   | 3   | 4     | 5       |                    | 6       | 7     | 8   | 9   | 0 | \          |
// | TAB  | Q | W   | E   | R     | T       |                    | Y       | U     | I   | O   | P | [          |
// | `    | A | S   | D   | F     | G       |                    | H       | J     | K   | L   | ; | '          |
// | CTRL | Z | X   | C   | V     | B       | MUTE  |  | RGB_TOG | N       | M     | ,   | .   | / | ENTER/CTRL |
//            | GUI | ALT | SHIFT | SYMBOLS | SPACE |  | BKSPC   | EDITING | SHIFT | ALT | GUI |
            display-name = "Base";
            bindings = <
&kp ESC   &kp N1 &kp N2   &kp N3   &kp N4    &kp N5                                  &kp N6      &kp N7    &kp N8    &kp N9   &kp N0   &kp PIPE
&kp TAB   &kp Q  &kp W    &kp E    &kp R     &kp T                                   &kp Y       &kp U     &kp I     &kp O    &kp P    &kp LBKT
&kp GRAVE &kp A  &kp S    &kp D    &kp F     &kp G                                   &kp H       &kp J     &kp K     &kp L    &kp SEMI &kp SQT
&kp LCTRL &kp Z  &kp X    &kp C    &kp V     &kp B       &kp C_MUTE  &rgb_ug RGB_TOG &kp N       &kp M     &kp COMMA &kp DOT  &kp FSLH &mt RCTRL RET
                 &kp LGUI &kp LALT &kp LSHFT &mo SYMBOLS &kp SPACE   &kp BSPC        &mo EDITING &kp RSHFT &kp RALT  &kp RGUI
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LC(LG(LEFT)) LC(LG(RIGHT))>;
        };

        gaming_layer {
// ------------------------------------------------------------------------------------------------------------------
// | ESC   | 1 | 2   | 3   | 4    | 5       |                    | 6       | 7    | 8   | 9   | 0 | \           |
// | TAB   | Q | W   | E   | R    | T       |                    | Y       | U    | I   | O   | P | [           |
// | `     | A | S   | D   | F    | G       |                    | H       | J    | K   | L   | ; | '           |
// | SHIFT | Z | X   | C   | V    | B       | MUTE  |  | RGB_TOG | N       | M    | ,   | .   | / | ENTER/SHIFT |
//             | GUI | ALT | CTRL | SYMBOLS | SPACE |  | BKSPC   | EDITING | CTRL | ALT | GUI |
            display-name = "Gaming";
            bindings = <
&kp ESC   &kp N1 &kp N2   &kp N3   &kp N4    &kp N5                                  &kp N6      &kp N7    &kp N8    &kp N9   &kp N0   &kp PIPE
&kp TAB   &kp Q  &kp W    &kp E    &kp R     &kp T                                   &kp Y       &kp U     &kp I     &kp O    &kp P    &kp LBKT
&kp GRAVE &kp A  &kp S    &kp D    &kp F     &kp G                                   &kp H       &kp J     &kp K     &kp L    &kp SEMI &kp SQT
&kp LSHFT &kp Z  &kp X    &kp C    &kp V     &kp B       &kp C_MUTE  &rgb_ug RGB_TOG &kp N       &kp M     &kp COMMA &kp DOT  &kp FSLH &mt RSHFT RET
                 &kp LGUI &kp LALT &kp LCTRL &mo SYMBOLS &kp SPACE   &kp BSPC        &mo EDITING &kp RCTRL &kp RALT  &kp RGUI
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LC(LG(LEFT)) LC(LG(RIGHT))>;
        };

        symbols_layer {
// ------------------------------------------------------------------------------------------------------------
// |     | F1 | F2 | F3 | F4 | F5 |                  | F6 | F7 | F8 | F9 | F10 | F11 |
// | ESC | 1  | 2  | 3  | 4  | 5  |                  | 6  | 7  | 8  | 9  | 0   | F12 |
// | `   | !  | @  | #  | $  | %  |                  | ^  | &  | *  | (  | )   | |   |
// |     | =  | -  | +  | {  | }  |       |  |       | [  | ]  | ;  | :  | \   |     |
//            |    |    |    |    |       |  |       |    |    |    |    |
            display-name = "Symbols";
            bindings = <
&trans    &kp F1    &kp F2    &kp F3   &kp F4   &kp F5                   &kp F6    &kp F7   &kp F8    &kp F9    &kp F10  &kp F11
&kp ESC   &kp N1    &kp N2    &kp N3   &kp N4   &kp N5                   &kp N6    &kp N7   &kp N8    &kp N9    &kp N0   &kp F12
&kp GRAVE &kp EXCL  &kp AT    &kp HASH &kp DLLR &kp PRCNT                &kp CARET &kp AMPS &kp ASTRK &kp LPAR  &kp RPAR &kp PIPE
&trans    &kp EQUAL &kp MINUS &kp PLUS &kp LBRC &kp RBRC  &trans  &trans &kp LBKT  &kp RBKT &kp SEMI  &kp COLON &kp BSLH &trans
                    &trans    &trans   &trans   &trans    &trans  &trans &trans    &trans   &trans    &trans
            >;
            sensor-bindings = <&inc_dec_kp LC(LG(LEFT)) LC(LG(RIGHT)) &inc_dec_kp C_VOL_DN C_VOL_UP>;
        };

        editing_layer {
// ------------------------------------------------------------------------------------------------------------
// |   |      |      |       |       |      |                  |      |       |    |      |   |   |
// |   | INS  | PSCR | CMENU |       |      |                  | PGUP | BKSPC | ^  | DEL  |   |   |
// |   | GUI  | ALT  | CTRL  | SHIFT | CAPS |                  | PGDN | <-    | v  | ->   |   |   |
// |   | UNDO | CUT  | COPY  | PASTE |      |       |  |       |      |       |    |      |   |   |
//            |      |       |       |      |       |  |       |      | PREV  | PP | NEXT |
            display-name = "Editing";
            bindings = <
&trans &trans    &trans    &trans      &trans      &trans                  &trans    &trans     &trans   &trans     &trans &trans
&trans &kp INS   &kp PSCRN &kp K_CMENU &trans      &trans                  &kp PG_UP &kp BSPC   &kp UP   &kp DEL    &trans &trans
&trans &kp LGUI  &kp LALT  &kp LCTRL   &kp LSHFT   &kp CLCK                &kp PG_DN &kp LEFT   &kp DOWN &kp RIGHT  &trans &trans
&trans &kp LC(Z) &kp K_CUT &kp K_COPY  &kp K_PASTE &trans   &trans  &trans &trans    &trans     &trans   &trans     &trans &trans
                 &trans    &trans      &trans      &trans   &trans  &trans &trans    &kp C_PREV &kp C_PP &kp C_NEXT 
            >;
            sensor-bindings = <&inc_dec_kp LC(LG(LEFT)) LC(LG(RIGHT)) &inc_dec_kp C_VOL_DN C_VOL_UP>;
        };

        adjust_layer {
// ----------------------------------------------------------------------------------------------------------------------------
// | BTCLR  | BT1     | BT2     | BT3     | BT4     | BT5     |                  | GAME | BASE |      |      |      |      |
// | EXTPWR | RGB_HUD | RGB_HUI | RGB_SAD | RGB_SAI | RGB_EFF |                  |      |      |      |      |      |      |
// |        | RGB_BRD | RGB_BRI |         |         |         |                  |      |      |      |      |      |      |
// |        |         |         |         |         |         | RGB_TOG | |      |      |      |      |      |      |      |
//                    |         |         |         |         |         | |      |      |      |      |      |
            display-name = "Adjust";
            bindings = <
&bt BT_CLR        &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4                   &to GAMING &to BASE &none &none &none &none
&ext_power EP_TOG &rgb_ug RGB_HUD &rgb_ug RGB_HUI &rgb_ug RGB_SAD &rgb_ug RGB_SAI &rgb_ug RGB_EFF                &none      &none    &none &none &none &none
&none             &rgb_ug RGB_BRD &rgb_ug RGB_BRI &none           &none           &none                          &none      &none    &none &none &none &none
&none             &none           &none           &none           &none           &none            &none  &none  &none      &none    &none &none &none &none
                                  &none           &none           &none           &none            &none  &none  &none      &none    &none &none
            >;
        };

        extra2 {
            status = "reserved";
        };

        extra3 {
            status = "reserved";
        };

        extra4 {
            status = "reserved";
        };
    };
};
